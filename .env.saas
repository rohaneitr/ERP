APP_NAME="FastPos"
APP_TITLE=""
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_LOG_LEVEL=error
APP_URL=https://erp.fstio.com
APP_LOCALE=en
APP_TIMEZONE="Asia/Dhaka"

# ─── Multi-tenant Superadmin Mode ──────────────────────────────────────────
# ONE deployment manages ALL clients as separate "businesses"
# Superadmin can: create businesses, assign packages, switch into any account
SUPERADMIN_MODE=true
ADMINISTRATOR_USERNAMES=fstadmin  # ← admin user-এর username হতে হবে এটা
ALLOW_REGISTRATION=true           # ← client নিজে register করতে পারবে
ENABLE_GST_REPORT_INDIA=
SHOW_REPAIR_STATUS_LOGIN_SCREEN=false

LOG_CHANNEL=daily
POS_RECENT_TRANSACTIONS_DISPLAY_LIMIT=10

# ─── Database (set in Coolify environment variables) ─────────────────────────
DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=fastpos_saas
DB_USERNAME=
DB_PASSWORD=

BROADCAST_DRIVER=pusher
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=fctbd1@gmail.com
MAIL_FROM_NAME="FastPos"

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=

BACKUP_DISK="local"
DROPBOX_ACCESS_TOKEN=

# ─── Superadmin Payment Gateways ─────────────────────────────────────────────
STRIPE_PUB_KEY=
STRIPE_SECRET_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_APP_SECRET=
PAYPAL_MODE=live
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
PESAPAL_CURRENCY=BDT
PESAPAL_LIVE=true
GOOGLE_MAP_API_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_PAYMENT_URL=https://api.paystack.co
MERCHANT_EMAIL="fctbd1@gmail.com"
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=

# ─── AI Assistance ───────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_ORGANIZATION=

# ─── AWS S3 Backup ───────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
AWS_BUCKET=

MY_FATOORAH_API_KEY=
MY_FATOORAH_IS_TEST=
MY_FATOORAH_COUNTRY_ISO=

ENABLE_RECAPTCHA="false"
GOOGLE_RECAPTCHA_KEY=
GOOGLE_RECAPTCHA_SECRET=

DO_NOT_ALLOW_DISPOSABLE_EMAIL=true
