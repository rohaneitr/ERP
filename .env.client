APP_NAME="FastPos"
APP_TITLE=""
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_LOG_LEVEL=error
APP_URL=https://CLIENT_DOMAIN_HERE
APP_LOCALE=en
APP_TIMEZONE="Asia/Dhaka"

# ─── Superadmin: DISABLED (Client mode) ─────────────────────────────────────
# Superadmin panel is completely hidden in client deployments.
# /superadmin/* routes return 404. Subscription system is bypassed.
SUPERADMIN_MODE=false
ADMINISTRATOR_USERNAMES=
ALLOW_REGISTRATION=true
ENABLE_GST_REPORT_INDIA=
SHOW_REPAIR_STATUS_LOGIN_SCREEN=false

LOG_CHANNEL=daily
POS_RECENT_TRANSACTIONS_DISPLAY_LIMIT=10

# ─── Database ────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=fastpos_CLIENT_NAME
DB_USERNAME=
DB_PASSWORD=

BROADCAST_DRIVER=pusher
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=fctbd1@gmail.com
MAIL_FROM_NAME="FastPos"

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=

BACKUP_DISK="local"

OPENAI_API_KEY=
OPENAI_ORGANIZATION=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
AWS_BUCKET=

ENABLE_RECAPTCHA="false"
GOOGLE_RECAPTCHA_KEY=
GOOGLE_RECAPTCHA_SECRET=

DO_NOT_ALLOW_DISPOSABLE_EMAIL=false
